# OpenAI API Key — 강사 Organization 초대 수락 후 발급한 "개인 프로젝트 키"
# 발급 즉시 복사해서 아래에 붙여넣으세요 (한 번만 보여집니다).
# 이 파일을 복사한 .env 는 절대 commit 하지 마세요 (.gitignore 에 등록됨).
OPENAI_API_KEY=sk-...

# (선택) LangSmith 트레이싱 — LangChain 실행 과정을 웹에서 추적.
# 키가 없어도 노트북은 동작합니다(트레이싱만 비활성).
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=chatgpt-handson
